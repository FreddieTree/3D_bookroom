# 复制此文件为 `.env.local` 并填入密钥（永远不要提交 `.env.local`）。
# 本 `.env.example` 可提交到 git，敏感值留空或注释。

# ---------------------------------------------------------------------------
# MiniMax（成员 2 对话 · 成员 3 生成）
# ---------------------------------------------------------------------------
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TEXT_MODEL=

# ---------------------------------------------------------------------------
# MongoDB Atlas（与 `mongoose` / `npm run db:seed` 对应）
# ---------------------------------------------------------------------------
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?appName=Cluster0
# MONGODB_DB=bookroom

# ---------------------------------------------------------------------------
# 前端公用开关（构建期注入 NEXT_PUBLIC_*）
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_APP_NAME=三维书屋
# 若为 "true"，`app/lib/data-source.ts` 中适配器可走 `/api/*` 而非纯 mock。
# NEXT_PUBLIC_USE_REAL_DB=false
# DirectorDock / `?demo=director`，需同时为 true。（见 app/lib/env/demo.ts）
# NEXT_PUBLIC_DEMO_MODE=false

# AI provider（成员 2）。默认 local：本地确定性引擎；minimax 走远端占位实现。
# NEXT_PUBLIC_AI_PROVIDER=local

# 阅读进度：`ReadingProgressBackgroundSync` 静默 PATCH + sendBeacon
# NEXT_PUBLIC_BACKGROUND_PROGRESS_SYNC=true
# NEXT_PUBLIC_PROGRESS_SYNC_DEBOUNCE_MS=9000

# 统计 API：`GET /api/admin/db-stats`（默认 404，避免生产误暴露）
# ENABLE_DB_STATS_ADMIN=true

# ---------------------------------------------------------------------------
# 可选部署
# ---------------------------------------------------------------------------
# Vercel（用于 metadataBase，本地可省略）
# VERCEL_URL=your-deployment.vercel.app

# ---------------------------------------------------------------------------
# 后续 Cloudinary CDN 等资源（占位）
# ---------------------------------------------------------------------------
# CLOUDINARY_URL=
