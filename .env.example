# Copy to .env.local for production-like demo / 路演
# NEXT_PUBLIC_DEMO_MODE=true
# Optional: URL ?demo=director 打开导演模式（浮动跳转按钮）

# MiniMax server-side credentials. Do not expose these with NEXT_PUBLIC_.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TEXT_MODEL=

# AI provider 切换（成员 2）。默认 local：使用本地确定性引擎，零网络依赖。
# 切到 minimax 时会启用远端占位类（当前抛 NotImplemented，Phase 2 接入）。
# NEXT_PUBLIC_AI_PROVIDER=local
