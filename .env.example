# Copy to `.env.local` for local demo / deployments

# MiniMax API
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# MongoDB Atlas — never commit secrets; rotate if leaked.
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?appName=Cluster0
# MONGODB_DB=bookroom

# Cloudinary (later)
# CLOUDINARY_URL=

# App
# NEXT_PUBLIC_APP_NAME=三维书屋
# Frontend: mock data until teammates wire services
# NEXT_PUBLIC_USE_REAL_DB=false

# 「三维书屋」阅读进度静默回写 Atlas（防抖 + pagehide/sendBeacon）。
# NEXT_PUBLIC_BACKGROUND_PROGRESS_SYNC=true
# NEXT_PUBLIC_PROGRESS_SYNC_DEBOUNCE_MS=9000
