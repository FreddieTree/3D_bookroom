# Copy to .env.local for production-like demo / 路演
# NEXT_PUBLIC_DEMO_MODE=true
# Optional: URL ?demo=director 打开导演模式（浮动跳转按钮）

# Anthropic-compatible 网关凭据（server-only，严禁加 NEXT_PUBLIC_）。
# /api/chat 路由会用它们调用 /v1/messages stream。
# 注意：用 MINIMAX_ 前缀而不是 ANTHROPIC_，以免被系统级 ANTHROPIC_* env（如 Claude Code）覆盖
# .env.local。
MINIMAX_AUTH_TOKEN=
MINIMAX_BASE_URL=
MINIMAX_MODEL=

# AI provider 切换（成员 2）。默认 local：使用本地确定性引擎，零网络依赖。
# 切到 minimax 时启用 MinimaxAiProvider（走 /api/chat → 网关）。
# NEXT_PUBLIC_AI_PROVIDER=local
