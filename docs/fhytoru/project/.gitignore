# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# PWA build artifacts (generated by `next build --webpack`)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/fallback-*.js
/public/swe-worker-*.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python pipeline artifacts
multimodel/__pycache__/
multimodel/output/
multimodel/*.stackdump
multimodel/gen_sample_content.py
multimodel/sync_assets.py

# Crash dumps and temp screenshots
*.stackdump
bash.exe.stackdump
demo-*.png
before-*.png

# Playwright debug artifacts
.playwright-cli/
output/

# Local env variants (root .env.local is the source of truth)
multimodel/.env
